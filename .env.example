# Required: Secret for authenticating requests to this worker
BROWSER_WORKER_SECRET=your-strong-secret-here

# Optional: Comma-separated list of allowed hostnames (leave empty to allow all public hosts)
BROWSER_ALLOWED_HOSTS=

# Optional: Maximum concurrent browser jobs (default: 2)
BROWSER_MAX_CONCURRENT_JOBS=2

# Optional: Maximum steps per job (default: 25)
BROWSER_MAX_STEPS=25

# Optional: Maximum job runtime in ms (default: 120000)
BROWSER_MAX_RUNTIME_MS=120000

# Optional: Maximum screenshots per job (default: 6)
BROWSER_MAX_SCREENSHOTS=6

# Optional: Block private networks in SSRF check (default: true)
BROWSER_BLOCK_PRIVATE_NETWORKS=true

# Optional: Log level (default: info)
BROWSER_LOG_LEVEL=info

# Optional: Artifact storage backend (supabase | s3 | none)
BROWSER_ARTIFACT_STORAGE=none

# Optional: Artifact storage bucket name
BROWSER_ARTIFACT_BUCKET=
